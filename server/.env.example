# Αντίγραψέ το σε .env και προσάρμοσέ το. Όλα έχουν λογικά defaults.

# HTTP
PORT=8080

# Βάση (SQLite αρχείο). ':memory:' για προσωρινή.
DB_PATH=./data/democratia.db

# Μυστικό HMAC για ανωνυμοποίηση ψηφοφόρων — ΑΛΛΑΞΕ ΤΟ σε production.
VOTER_SECRET=change-me-to-a-long-random-string

# Κωδικός για τη σελίδα διαχείρισης /admin (καταχώρηση ψηφισμάτων Βουλής).
# Αν μείνει κενός, η διαχείριση είναι ΑΠΕΝΕΡΓΟΠΟΙΗΜΕΝΗ. Όρισέ τον (μακρύ & τυχαίο).
ADMIN_TOKEN=

# Origin του frontend για CORS (π.χ. https://democratia.vercel.app). '*' = όλα.
CORS_ORIGIN=*

# Μυστικό για ταυτοποίηση (hash ΑΦΜ/OTP, session tokens). ΑΛΛΑΞΕ ΤΟ.
AUTH_SECRET=change-me-to-a-long-random-string
# Διάρκειες/όρια ταυτοποίησης
SESSION_TTL_MS=604800000   # 7 ημέρες
OTP_TTL_MS=300000          # 5 λεπτά
OTP_MAX_ATTEMPTS=5
# Σε προσομοίωση το OTP επιστρέφεται στην απόκριση. Σε production: false + SMS πάροχος.
SIMULATE_OTP=true
# Έκδοση όρων/πολιτικής (για καταγραφή συγκαταθέσεων)
POLICY_VERSION=2025-06-01

# Φόρτωση seed δεδομένων αν η βάση είναι άδεια.
SEED_ON_EMPTY=true

# ── Αυτόματος συγχρονισμός ──────────────────────────────────────────────────
# Ποιες πηγές: europarl,hellenic
SYNC_SOURCES=europarl,hellenic
SYNC_INTERVAL_MS=21600000        # 6 ώρες
SYNC_LOOKBACK_DAYS=120

# European Parliament Open Data API (v2)
EUROPARL_API_BASE=https://data.europarl.europa.eu/api/v2

# Ελληνικό Κοινοβούλιο: URL feed με δομημένα δεδομένα ψηφοφοριών.
# Δες server/README.md για την αναμενόμενη μορφή JSON.
HELLENIC_FEED_URL=

# ── Χρονοπρογραμματιστής ────────────────────────────────────────────────────
SCHEDULER_ENABLED=true
SCHEDULER_TICK_MS=60000          # 1 λεπτό
